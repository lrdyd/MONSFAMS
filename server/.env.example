# ===========================================
# MONSFAMS Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Server Port
PORT=3000

# Admin Password (CHANGE THIS!)
ADMIN_PASSWORD=MONSFAMS

# Premium Password (untuk user biasa akses premium)
PREMIUM_PASSWORD=MONSFAMS

# Max File Size in Bytes (0 = Unlimited / tanpa batas)
MAX_FILE_SIZE=0

# Allowed CORS Origins (comma separated)
# Leave empty to allow all origins
ALLOWED_ORIGINS=

# Node Environment
NODE_ENV=production

# ===========================================
# Rate Limiting (Otomatis aktif, tidak perlu di-set)
# ===========================================
# API: 100 requests per minute per IP
# Downloads: 30 downloads per minute per IP
# Concurrent Downloads: 5 per IP simultaneously
# Cleanup: Otomatis setiap 1 menit
